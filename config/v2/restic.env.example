# Copy to /etc/vps-control/restic.env on the VPS.
# Keep the real file root-owned and mode 0400 or 0640.
# Configure an SSH Host alias for the Storage Box with port 23 and the
# dedicated /etc/vps-control/storagebox_ed25519 identity file.

RESTIC_REPOSITORY=sftp:<storagebox-host-alias>:restic/<server-id>
RESTIC_PASSWORD_FILE=/etc/vps-control/restic-passphrase
