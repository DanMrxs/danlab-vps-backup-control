# Copy to /etc/vps-control/config.env on the VPS.
# This file should contain operational settings only, not provider keys.

SERVER_ID=danlab-vps
CONTROL_REPO=/opt/vps-backup-control
WORK_ROOT=/var/backups/vps-control/work
LOG_ROOT=/var/log/vps-control
RESTIC_ENV_FILE=/etc/vps-control/restic.env
HEALTHCHECKS_ENV_FILE=/etc/vps-control/healthchecks.env
RESTIC_REPOSITORY_ALIAS=hetzner-storage-box

POSTGRES_CONTAINER_FILTER=postgres_postgres
PGVECTOR_CONTAINER_FILTER=pgvector_pgvector
REDIS_CONTAINER_FILTER=redis_redis
POSTGRES_USER=postgres
PGVECTOR_USER=postgres
RESTORE_POSTGRES_IMAGE=postgres:14

VOLUME_NAMES="baserow_data chatwoot_data contentos-tools_searxng-config evolutionv2_instances minio_data portainer_data volume_swarm_certificates"
