# Copy to /etc/vps-control/healthchecks.env on the VPS.
# Ping URLs are secrets. Never commit the real file.

HC_DAILY_URL=https://hc-ping.com/<daily-backup-uuid>
HC_WEEKLY_URL=https://hc-ping.com/<weekly-backup-uuid>
HC_MONTHLY_URL=https://hc-ping.com/<monthly-restore-drill-uuid>

HC_DAILY_SLUG=vps-backup-daily
HC_WEEKLY_SLUG=vps-backup-weekly
HC_MONTHLY_SLUG=vps-restore-monthly
